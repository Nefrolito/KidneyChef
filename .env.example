ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# Clave compartida con la app. Debe coincidir con la constante APP_KEY de
# public/app.js. No es un secreto real (viaja en el código del cliente), sirve
# para que quien descubra la URL del backend no pueda usarlo directamente.
# Si se deja vacía, no se exige — cómodo para desarrollo local.
APP_KEY=

# Límites de uso de /api/analyze (opcionales, estos son los valores por defecto).
# RATE_LIMIT_PER_IP=20
# RATE_LIMIT_PER_IP_WINDOW=3600
# RATE_LIMIT_GLOBAL=500
# RATE_LIMIT_GLOBAL_WINDOW=86400
