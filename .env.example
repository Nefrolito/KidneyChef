ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# Clave compartida con la app. Debe coincidir con la constante APP_KEY de
# public/app.js. No es un secreto real (viaja en el código del cliente), sirve
# para que quien descubra la URL del backend no pueda usarlo directamente.
# Si se deja vacía, no se exige — cómodo para desarrollo local.
APP_KEY=

# Límites de uso de /api/analyze (opcionales, estos son los valores por defecto).
# RATE_LIMIT_PER_IP=20
# RATE_LIMIT_PER_IP_WINDOW=3600
# RATE_LIMIT_GLOBAL=500
# RATE_LIMIT_GLOBAL_WINDOW=86400

# Tope de tamaño del body de /api/analyze, en bytes (opcional, 8 MB por defecto).
# MAX_BODY_BYTES=8388608

# --- Vínculo con el equipo tratante (portal en /tratante/) ---------------
# Proyecto de Supabase (Project Settings → API en supabase.com/dashboard).
# SUPABASE_SERVICE_KEY es la key "service_role": la usa server.py para leer y
# escribir sin pasar por Row Level Security (la lógica de permisos vive en
# Python, no en RLS) — NUNCA debe llegar al navegador ni a tratante/config.js.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# SUPABASE_ANON_KEY solo hace falta en el servidor para validar el token del
# tratante (server.py llama a /auth/v1/user de Supabase). Es la misma key
# pública que va en tratante/config.js — no es un secreto.
SUPABASE_ANON_KEY=

# Rate limit de POST /api/vinculos por cuenta de tratante, para que no sirva
# de fuerza bruta contra códigos de cliente de pacientes (opcionales).
# VINCULOS_RATE_LIMIT_POR_TRATANTE=10
# VINCULOS_RATE_LIMIT_WINDOW=3600
